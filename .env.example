# API Keys Configuration
# Copy this file to .env and fill in your actual API keys

# Google Gemini API Key
# Get it from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# LangSmith API Key (optional, for monitoring and tracing)
# Get it from: https://smith.langchain.com/
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=real-estate-agent-darija

# Optional: LangChain Hub
LANGCHAIN_HUB_API_KEY=your_langchain_hub_key_here
